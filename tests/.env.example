# Resend (test_resend.py)
RESEND_API_KEY=your-resend-api-key
RESEND_TEST_TO=you@example.com
RESEND_TEST_FROM=noreply@yourdomain.com

# Contact form E2E (test_contact_form.py) — both optional, defaults shown
CONTACT_URL=https://rynodetailing.com/contact
CONTACT_TEST_EMAIL=you@example.com

# Supabase Management API (apply_schema.py) — personal access token, sbp_...
SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref

# Supabase PostgREST (test_supabase_rls.py)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
